FROM docker.io/eclipse-temurin:21-jdk-alpine AS builder
WORKDIR /workspace
COPY . .
RUN --mount=type=cache,target=/root/.m2 ./mvnw package -pl auth-service -am -DskipTests -q

FROM docker.io/eclipse-temurin:21-jre-alpine
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
RUN mkdir -p /secrets/auth && chown appuser:appgroup /secrets/auth
WORKDIR /app
RUN mkdir -p /app/logs/auth-service && chown appuser:appgroup /app/logs/auth-service
COPY --from=builder --chown=appuser:appgroup /workspace/auth-service/target/*.jar app.jar
USER appuser
EXPOSE 1081
HEALTHCHECK --interval=15s --timeout=10s --start-period=60s --retries=5 \
  CMD wget -qO- http://localhost:1081/actuator/health | grep -q '"status":"UP"' || exit 1
ENTRYPOINT ["java", "-jar", "app.jar"]
