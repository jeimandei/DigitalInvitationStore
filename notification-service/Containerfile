FROM docker.io/eclipse-temurin:21-jdk-alpine AS builder
WORKDIR /build
COPY . .
RUN ./mvnw -pl notification-service -am -q -DskipTests package && \
    java -Djarmode=layertools -jar notification-service/target/notification-service-*.jar extract --destination notification-service/target/extracted

FROM docker.io/eclipse-temurin:21-jre-alpine
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
WORKDIR /app

RUN mkdir -p /app/logs/notification-service && chown appuser:appgroup /app/logs/notification-service
COPY --from=builder --chown=appuser:appgroup /build/notification-service/target/extracted/dependencies/ ./
COPY --from=builder --chown=appuser:appgroup /build/notification-service/target/extracted/spring-boot-loader/ ./
COPY --from=builder --chown=appuser:appgroup /build/notification-service/target/extracted/snapshot-dependencies/ ./
COPY --from=builder --chown=appuser:appgroup /build/notification-service/target/extracted/application/ ./
USER appuser
EXPOSE 8087
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD wget -qO- http://localhost:8087/actuator/health || exit 1
ENTRYPOINT ["java", "org.springframework.boot.loader.launch.JarLauncher"]
