# ── PostgreSQL (single instance, all schemas in DB "baundang") ────────────────

DB_USER=baundang
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_PASSWORD=changeme

# ── RabbitMQ ──────────────────────────────────────────────────────────────────

RABBITMQ_USER=baundang
RABBITMQ_PASSWORD=changeme

# ── MinIO ─────────────────────────────────────────────────────────────────────

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ── Config Server ─────────────────────────────────────────────────────────────

CONFIG_SERVER_USER=config
CONFIG_SERVER_PASSWORD=changeme

# ── Auth ──────────────────────────────────────────────────────────────────────

JWT_SECRET=replace-with-256-bit-base64-secret

# ── Payment ───────────────────────────────────────────────────────────────────

MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx

# ── Notification ──────────────────────────────────────────────────────────────

WHATSAPP_API_TOKEN=your-fonnte-api-token

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=noreply@baundang.id
EMAIL_PASSWORD=changeme
