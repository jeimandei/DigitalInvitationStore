FROM docker.io/eclipse-temurin:21-jdk-alpine AS builder
WORKDIR /workspace
COPY . .
RUN ./mvnw package -pl template-service -am -DskipTests -q

FROM docker.io/eclipse-temurin:21-jre-alpine
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
WORKDIR /app
RUN mkdir -p /app/logs/template-service && chown appuser:appgroup /app/logs/template-service
COPY --from=builder --chown=appuser:appgroup /workspace/template-service/target/*.jar app.jar
USER appuser
EXPOSE 1083
HEALTHCHECK --interval=15s --timeout=10s --start-period=60s --retries=5 \
  CMD wget -qO- http://localhost:1083/actuator/health | grep -q '"status":"UP"' || exit 1
ENTRYPOINT ["java", "-jar", "app.jar"]
