FROM eclipse-temurin:25-jdk-alpine AS builder
WORKDIR /build
COPY . .
RUN ./mvnw -pl order-service -am -q -DskipTests package && \
    java -Djarmode=layertools -jar order-service/target/order-service-*.jar extract --destination order-service/target/extracted

FROM eclipse-temurin:25-jre-alpine
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
WORKDIR /app
COPY --from=builder --chown=appuser:appgroup /build/order-service/target/extracted/dependencies/ ./
COPY --from=builder --chown=appuser:appgroup /build/order-service/target/extracted/spring-boot-loader/ ./
COPY --from=builder --chown=appuser:appgroup /build/order-service/target/extracted/snapshot-dependencies/ ./
COPY --from=builder --chown=appuser:appgroup /build/order-service/target/extracted/application/ ./
USER appuser
EXPOSE 8085
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD wget -qO- http://localhost:8085/actuator/health || exit 1
ENTRYPOINT ["java", "org.springframework.boot.loader.launch.JarLauncher"]
